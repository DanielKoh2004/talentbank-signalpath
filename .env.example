# Database
# Neon connection string. Use the pooled URL for Vercel/serverless.
# Example:
# DATABASE_URL="postgresql://USER:PASSWORD@ep-example-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# AI Provider (OpenAI-compatible)
AI_API_KEY="your-api-key-here"
AI_BASE_URL="https://your-provider.com/v1"
AI_MODEL="your-model-name"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
